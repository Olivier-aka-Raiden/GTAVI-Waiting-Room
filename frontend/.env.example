# Frontend environment variables
# Copy to .env.local for local dev (gitignored)
# Set the same vars in Vercel dashboard for production (Settings → Environment Variables)

# ---- Firebase (public values — from Firebase Console → Project Settings → Web App) ----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---- VAPID key (Firebase Console → Cloud Messaging → Web Push certificates) ----
VITE_FIREBASE_VAPID_KEY=

# ---- API base URL (only needed if NOT using Vercel rewrites) ----
# VITE_API_BASE_URL=https://gtavi-api-xxxxxxxxxx-ew.a.run.app
