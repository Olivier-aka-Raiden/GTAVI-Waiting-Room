# ============================================================
# GTA VI Waiting Room — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ---- Neo4j ----
# Local Docker: bolt://localhost:7687
# AuraDB Free:   neo4j+s://<dbid>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ---- DeepSeek AI (for monitoring extraction) ----
# Get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- Firebase Cloud Messaging ----
# Set to true when Firebase is configured
FCM_ENABLED=false
# Base64-encoded service account JSON or path to file
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---- Monitoring ----
MONITORING_ENABLED=false

# ---- Internal Job Security ----
# Shared secret for /internal/* endpoints (when OIDC is not configured)
# Generate with: openssl rand -hex 32
INTERNAL_SHARED_SECRET=dev-secret-change-me-in-production
